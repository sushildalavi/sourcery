# --- build stage ---------------------------------------------------------
FROM node:25-alpine AS build
WORKDIR /app

# Pull deps first so the npm install layer caches across source edits.
COPY package.json package-lock.json ./
RUN npm ci

COPY . .
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN npm run build

# --- runtime stage -------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# SPA fallback so client-side routes (/public, /analytics, ...) don't 404
# on a hard refresh.
RUN printf 'server {\n  listen 80;\n  root /usr/share/nginx/html;\n  index index.html;\n  location / {\n    try_files $uri /index.html;\n  }\n}\n' > /etc/nginx/conf.d/default.conf

COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s --retries=3 CMD wget -qO- http://127.0.0.1/ >/dev/null 2>&1 || exit 1
