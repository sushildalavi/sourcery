# Copy to .env and fill in. Never commit the real .env.

# --- Postgres (matches docker-compose db service defaults) ---
DATABASE_URL=postgresql://scholarrag:scholarrag@127.0.0.1:5432/scholarrag
# Or set the discrete vars and the db service will compose them.
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=scholarrag
PGPASSWORD=scholarrag
PGDATABASE=scholarrag
PG_POOL_MIN=1
PG_POOL_MAX=10

# --- OpenAI (generation + LLM judge) ---
OPENAI_API_KEY=sk-...
# If using AWS Secrets Manager instead of plain env:
# OPENAI_API_KEY_SECRET_ID=prod/sourcery/openai

# --- Embeddings ---
# Provider: ollama (default, local) or openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_VERSION=v1
EMBEDDING_BATCH_SIZE=16
EMBEDDING_PARALLEL_WORKERS=4
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_RETRY_ATTEMPTS=3
EMBEDDING_RETRY_DELAY=1.0
EMBEDDING_MAX_DOC_WORDS=400
EMBEDDING_MAX_QUERY_WORDS=64
EMBEDDING_RAW_DIM=1024

# Ollama (when EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
OLLAMA_EMBED_TIMEOUT=60

# OpenAI embeddings (when EMBEDDING_PROVIDER=openai)
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIMENSIONS=1536
OPENAI_EMBED_TIMEOUT=30

# --- Vector store contract ---
VECTOR_STORE_DIM=1536

# --- Backend self-reference (used by background workers) ---
BACKEND_BASE_URL=http://127.0.0.1:8000

# --- Optional: scholarly providers that need keys ---
SPRINGER_API_KEY=
ELSEVIER_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# --- Storage ---
STORAGE_DIR=storage
